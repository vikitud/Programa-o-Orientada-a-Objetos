import java.util.Scanner;

class Cliente {
    String nome;
    String telefone;

    public Cliente(String nome) {
        this(nome, "Não informado");
    }

    public Cliente(String nome, String telefone) {
        this.nome = nome;
        this.telefone = telefone;
    }
}

class Produto {
    String nome;
    double preco;

    public Produto(String nome) {
        this(nome, 0.0);
    }

    public Produto(String nome, double preco) {
        this.nome = nome;
        this.preco = preco;
    }
}

class Pedido {
    Cliente cliente;
    Produto produto1;
    Produto produto2;
    double valorTotal;

    public Pedido(Cliente cliente, Produto produto1) {
        this(cliente, produto1, null);
    }

    public Pedido(Cliente cliente, Produto produto1, Produto produto2) {
        this.cliente = cliente;
        this.produto1 = produto1;
        this.produto2 = produto2;
        calcularTotal();
    }

    public void calcularTotal() {
        valorTotal = produto1.preco;
        if (produto2 != null) {
            valorTotal += produto2.preco;
        }
    }

    public void exibirPedido() {
        System.out.println("===== PEDIDO =====\n");

        System.out.println("Cliente: " + cliente.nome);
        System.out.println("Telefone: " + cliente.telefone + "\n");

        System.out.println("Produto: " + produto1.nome);
        System.out.println("Preço: " + produto1.preco + "\n");

        if (produto2 != null) {
            System.out.println("Produto: " + produto2.nome);
            System.out.println("Preço: " + produto2.preco + "\n");
        }

        System.out.println("Total: " + valorTotal);
    }
}

public class Main {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.print("Nome: ");
        String nome = sc.nextLine();

        System.out.print("Telefone: ");
        String telefone = sc.nextLine();

        Cliente cliente;
        if (telefone.isEmpty()) {
            cliente = new Cliente(nome);
        } else {
            cliente = new Cliente(nome, telefone);
        }

        System.out.print("Produto 1: ");
        String nome1 = sc.nextLine();

        System.out.print("Preço 1: ");
        double preco1 = sc.nextDouble();
        sc.nextLine();

        Produto p1 = new Produto(nome1, preco1);

        System.out.print("Deseja outro produto? (s/n): ");
        String op = sc.nextLine();

        Produto p2 = null;

        if (op.equalsIgnoreCase("s")) {
            System.out.print("Produto 2: ");
            String nome2 = sc.nextLine();

            System.out.print("Preço 2: ");
            double preco2 = sc.nextDouble();

            p2 = new Produto(nome2, preco2);
        }

        Pedido pedido;

        if (p2 == null) {
            pedido = new Pedido(cliente, p1);
        } else {
            pedido = new Pedido(cliente, p1, p2);
        }

        pedido.exibirPedido();

        sc.close();
    }
}

